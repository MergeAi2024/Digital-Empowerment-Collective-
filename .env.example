# TOGETHER_API_KEY: Required for Together AI API calls.
# Get your key from https://together.ai
TOGETHER_API_KEY="YOUR_TOGETHER_API_KEY"

# VITE_GOOGLE_CLIENT_ID: Google OAuth Client ID for Sign-In.
# Set this in a .env file or keep it in the app for the demo.
VITE_GOOGLE_CLIENT_ID="102110764491-lasbljebinmrqebd8d82t5fp21ltbugq.apps.googleusercontent.com"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
